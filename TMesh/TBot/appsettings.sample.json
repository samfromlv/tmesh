{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./log.txt",
          "restrictedToMinimumLevel": "Error",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "TBot": {
    "MqttAddress": "<your mqtt address>",
    "MqttPort": 8883,
    "MqttUser": "tbot",
    "MqttPassword": "<your mqtt password>",
    "MqttAllowUntrustedCertificates": false,
    "MqttUseTls": true,
    "MqttTelegramTopic": "TProxy/prod/telegram/update",
    "MqttStatusTopic": "TBot/prod/status",
    "MqttMeshtasticTopicPrefix": "<your meshtastic topic prefix, like msh/US/+/2/e>",
    "MqttMeshtasticMapTopic": "<your meshtastic map topic, like msh/US/+/2/map/>",
    "PublicMqttAddress": "<your public mqtt address accessible to gateways>",
    "PublicMqttTopic": "<your public meshtastic topic prefix like msh/US/{{NetworkId}}>",
    "PublicFlasherAddress": "<your public flasher address>",
    "AdminTgContact": "<your contact info for admin, like a telegram username or url>",
    "TelegramApiToken": "<your telegram api token>",
    "TelegramWebhookSecret": "<your telegram webhook secret>",
    "TelegramBotUserName": "<your telegram bot username>",
    "TelegramUpdateWebhookUrl": "<your telegram update webhook url>",
    "TelegramBotMaxConnections": 5,
    "SQLiteConnectionString": "Data Source=/tbot/data/tbot.db",
    "OutgoingMessageHopLimit": 7,
    "OwnNodeInfoMessageHopLimit": 7,
    "InactiveGatewayCleanupDays": 14,
    "MeshtasticNodeId": "<your meshtastic node id, INT64 remove the quotes>",
    "MeshtasticNodeNameShort": "<your meshtastic node name short>",
    "MeshtasticNodeNameLong": "<your meshtastic node name long>",
    "AdminPassword": "<your admin password>",
    "MeshtasticPublicKeyBase64": "<your meshtastic public key base64, generate with /generatekeys>",
    "MeshtasticPrivateKeyBase64": "<your meshtastic private key base64, generate with /generatekeys>",
    "MeshtasticMaxOutgoingMessagesPerMinute": 30,
    "SentTBotNodeInfoEverySeconds": 3600,
    "MaxQueueLengthForChannelAckEmojis": 30,
    "BridgeAllowedExtraNodeIds": [],
    "DirectGatewayRoutingSeconds": 120,
    "BridgeDirectMessagesToGateways": true,
    "ReplyToPublicPingsViaDirectMessage": true,
    "PingWords": [ "ping" ],
    "TimeZone": "UTC",
    "Texts": {
      "PingReply": "pong",
      "NewDeviceWelcomeMessage_Template": "Welcome!{settings}{community}",
      "NewDeviceWelcomeMessage_Settings": " Settings: {url}.",
      "NewDeviceWelcomeMessage_Community": " Community: {url}",
      "PrivacyDisclaimer": "<your privacy disclaimer text to inform users about data handling>",
      "PingReplyWithNetworkUrl": "Pong.",
      "NotRegisteredDeviceReply": "{nodeName} is not registered with {botName} (Telegram)",
      "FakeMessageWarningReply": "This is fake message. I haven't sent it."
    },
    "AnalyticsPostgresConnectionString": "your_postgres_connection_string_here",
    "DefaultMqttPasswordDeriveSecret": "your_default_secret",
    "MqttUserPasswordDeriveSecrets": {
      "tbot": "your_tbot_secret",
      "tproxy": "your_tproxy_secret",
      "dev": "your_dev_secret"
    },
    "UpgradeDbOnStart": true,
    "DebugPacketsViaMqtt": false,
    "MapMqttServers": [
      {
        "Address": "<your public mqtt address>",
        "Port": 1883,
        "User": "<your mqtt user>",
        "Password": "<your mqtt password>",
        "UseTls": false,
        "AllowUntrustedCertificates": false,
        "EncryptedTopicPrefix": "<your encrypted topic prefix like msh/US/{{NetworkShortName}}/2/e>",
        "MapTopic": "<optional: your map topic like msh/US/{{NetworkShortName}}/2/map/>",
        "UplinkEnabled": false,
        "AnalyticsDownlinkEnabled": true,
        "DefaultNetworkId": null
      }
    ]
  }
}